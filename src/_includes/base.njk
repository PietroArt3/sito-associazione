<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>
    <link rel="stylesheet" href="/sito-associazione/css/style.css">

<style>
    /* Configurazione Header Orizzontale */
    .header-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between; /* Logo a sinistra, Menu a destra */
        align-items: center;            /* Allinea verticalmente al centro */
        padding: 10px 20px;
    }

    .logo-link {
        display: flex;
        align-items: center;
        text-decoration: none;
    }

    .logo-img {
        height: 60px; /* Altezza contenuta per non allungare il sito */
        width: auto;
        transition: transform 0.3s;
    }

    nav {
        display: flex;
        flex-wrap: wrap; /* Se lo schermo è piccolo, i link vanno a capo */
        justify-content: flex-end;
        gap: 15px;
    }

    nav a {
        text-decoration: none;
        color: #333;
        font-family: sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s;
    }

    nav a:hover { color: #0066cc; }

    /* Ottimizzazione per Mobile */
    @media (max-width: 768px) {
        .header-container {
            flex-direction: column; /* Su cellulare torna l'ordine verticale per comodità */
            gap: 15px;
        }
        nav {
            justify-content: center;
        }
    }

    nav { padding: 20px 0; text-align: center; font-family: sans-serif; }
    nav a { text-decoration: none; color: #333; margin: 0 10px; transition: color 0.3s; }
    nav a:hover { color: #0066cc; }
    footer { text-align: center; padding: 40px 20px; font-family: sans-serif; background-color: #f9f9f9; }
</style>

<div class="banner-30">
    <div class="scorrimento">
        30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO
    </div>
</div>

</head>
<body>

<header>
    <div class="header-container">
        <a href="/sito-associazione/" class="logo-link">
            <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO Carpi" class="logo-img">
        </a>

        <nav>
            <a href="/sito-associazione/"><b>Notizie</b></a>
            <a href="/sito-associazione/chi-siamo">Chi Siamo</a>
            <a href="/sito-associazione/fai-una-donazione">Donazioni</a>
            <a href="/sito-associazione/progetti">Progetti</a>
            <a href="/sito-associazione/servizi">Servizi</a>
            <a href="/sito-associazione/contatti">Contatti</a>
            <a href="/sito-associazione/trasparenza">Trasparenza</a>
            <a href="/sito-associazione/privacy">Privacy</a>
        </nav>
    </div>
</header>

    <hr style="border: 0; border-top: 1px solid #eee; margin: 0;">

    <main>
        {{ content | safe }}
    </main>

    <footer style="margin-top: 50px; border-top: 1px solid #eee;">
        <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 20px;">
            <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" style="width: 80px; border-radius: 8px;">
            <p style="margin: 0; color: #555;">
                <strong>Associazione Malati Oncologici ODV Carpi (MO)</strong><br>
                <span style="font-size: 0.9rem;">Via G. Molinari 2, Ospedale Ramazzini, Carpi MO | Tel: 059 6132038 - Email: amocarpi.odv@gmail.com</span>
            </p>
        </div>
    </footer>
</body>
</html>