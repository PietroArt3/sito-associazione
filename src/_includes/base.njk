<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>

    <style>
        /* 1. RESET GENERALE: Centra il corpo del sito */
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center; /* Forza il centraggio dei figli diretti */
            min-height: 100vh;
        }

        /* 2. BANNER: Occupa tutta la larghezza */
        .banner-30 {
            width: 100%;
            background: linear-gradient(90deg, #004a99, #0066cc);
            color: white;
            padding: 8px 0;
            overflow: hidden;
            white-space: nowrap;
            font-weight: bold;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .scorrimento {
            display: inline-block;
            padding-left: 100%;
            animation: scorri 20s linear infinite;
        }

        @keyframes scorri {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        /* 3. HEADER: Centrato con Grid */
        header {
            width: 100%;
            background-color: white;
            border-bottom: 1px solid #eee;
        }

        .header-container {
            max-width: 1100px;
            margin: 0 auto; /* CENTRA L'HEADER */
            display: grid;
            grid-template-columns: 80px 1fr 80px; /* Logo e Spacer bilanciati */
            align-items: center;
            padding: 10px 20px;
        }

        .logo-img {
            height: 45px;
            width: auto;
        }

        nav {
            display: flex;
            justify-content: center; /* CENTRA IL MENU NELLO SPAZIO RIMASTO */
            flex-wrap: wrap;
            gap: 20px;
        }

        nav a {
            text-decoration: none;
            color: #444;
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* 4. MAIN: Il cuore delle tue notizie */
        main {
            width: 100%;
            max-width: 850px; /* Larghezza ideale per leggere notizie */
            margin: 0 auto;  /* CENTRA IL CONTENUTO */
            padding: 40px 20px;
            box-sizing: border-box;
        }

        /* 5. FOOTER: Centrato */
        footer {
            width: 100%;
            background-color: #f9f9f9;
            border-top: 1px solid #eee;
            padding: 40px 20px;
            margin-top: auto; /* Spinge il footer in fondo se c'è poco testo */
            text-align: center;
        }

        .footer-content {
            max-width: 850px;
            margin: 0 auto;
        }

        @media (max-width: 800px) {
            .header-container {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }
            .header-spacer { display: none; }
        }
    </style>
</head>
<body>

    <div class="banner-30">
        <div class="scorrimento">
            30 ANNI DI AMO ❤ 30 ANNI DI AMO ❤ 30 ANNI DI AMO
        </div>
    </div>

    <header>
        <div class="header-container">
            <a href="/sito-associazione/">
                <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" class="logo-img">
            </a>

            <nav>
                <a href="/sito-associazione/"><b>Notizie</b></a>
                <a href="/sito-associazione/chi-siamo">Chi Siamo</a>
                <a href="/sito-associazione/fai-una-donazione">Donazioni</a>
                <a href="/sito-associazione/progetti">Progetti</a>
                <a href="/sito-associazione/servizi">Servizi</a>
                <a href="/sito-associazione/contatti">Contatti</a>
                <a href="/sito-associazione/trasparenza">Trasparenza</a>
            </nav>

            <div class="header-spacer"></div> </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-content">
            <p><strong>Associazione Malati Oncologici ODV Carpi (MO)</strong></p>
            <p style="font-size: 0.85rem; color: #666;">
                Via G. Molinari 2, Ospedale Ramazzini, Carpi MO | Tel: 059 6132038<br>
                Email: amocarpi.odv@gmail.com
            </p>
        </div>
    </footer>

</body>
</html>