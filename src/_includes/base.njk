<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>

    <style>
        /* RESET BASE */
        body {
            margin: 0;
            padding: 0;
            font-family: sans-serif;
            line-height: 1.5;
            color: #333;
            background-color: white;
        }

        /* BANNER - Compatto */
        .banner-30 {
            width: 100%;
            background: linear-gradient(90deg, #004a99, #0066cc);
            color: white;
            padding: 6px 0;
            overflow: hidden;
            white-space: nowrap;
            font-weight: bold;
            font-size: 0.85rem;
            text-transform: uppercase;
        }

        .scorrimento {
            display: inline-block;
            padding-left: 100%;
            animation: scorri 22s linear infinite;
        }

        @keyframes scorri {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        /* HEADER - CORRETTO PER AVVICINARE I COMPONENTI */
        header {
            width: 100%;
            background-color: white;
            border-bottom: 1px solid #eee;
            padding: 5px 0; /* Ridotto ulteriormente */
        }

        .header-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex; /* Cambiato da Grid a Flex */
            align-items: center; /* Allinea verticalmente logo e scritte */
            padding: 0 20px;
        }

        .logo-img {
            height: 45px; /* Leggermente più piccolo come richiesto */
            width: auto;
            display: block;
            margin-right: 30px; /* QUESTO CONTROLLA LA DISTANZA DAL MENU */
        }

        nav {
            display: flex;
            flex-wrap: wrap;
            gap: 15px; /* Distanza tra le singole voci del menu */
        }

        nav a {
            text-decoration: none;
            color: #444;
            font-size: 0.95rem;
            font-weight: 500;
            transition: color 0.3s;
        }

        nav a:hover { color: #0066cc; }
        nav a b { color: #0066cc; }

        /* MAIN */
        main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px 20px; /* Ridotto spazio sopra il contenuto */
        }

        /* FOOTER */
        footer {
            width: 100%;
            background-color: #f9f9f9;
            border-top: 1px solid #eee;
            padding: 30px 20px;
            text-align: center;
            margin-top: 50px;
        }

        .footer-content p {
            font-size: 0.95rem;
            margin: 5px 0;
            color: #555;
        }

        /* MOBILE */
        @media (max-width: 800px) {
            .header-container {
                flex-direction: column;
                text-align: center;
            }
            .logo-img {
                margin-right: 0;
                margin-bottom: 10px;
            }
        }
    </style>
</head>
<body>

    <div class="banner-30">
        <div class="scorrimento">
            30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ️️ ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO
        </div>
    </div>

    <header>
        <div class="header-container">
            <a href="/sito-associazione/">
                <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" class="logo-img">
            </a>

            <nav>
                <a href="/sito-associazione/"><b>Notizie</b></a>
                <a href="/sito-associazione/chi-siamo">Chi Siamo</a>
                <a href="/sito-associazione/fai-una-donazione">Donazioni</a>
                <a href="/sito-associazione/progetti">Progetti</a>
                <a href="/sito-associazione/servizi">Servizi</a>
                <a href="/sito-associazione/contatti">Contatti</a>
                <a href="/sito-associazione/trasparenza">Trasparenza</a>
            </nav>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-content">
            <p><strong>Associazione Malati Oncologici ODV Carpi (MO)</strong></p>
            <p>Via G. Molinari 2, Ospedale Ramazzini, Carpi MO | Tel: 059 6132038</p>
            <p>Email: amocarpi.odv@gmail.com</p>
        </div>
    </footer>

</body>
</html>