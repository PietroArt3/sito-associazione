<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>

    <style>
        /* RESET E BASE */
        body {
            margin: 0;
            padding: 0;
            font-family: sans-serif;
            line-height: 1.6;
            color: #333;
        }

        /* BANNER - Sempre a tutta larghezza */
        .banner-30 {
            width: 100%;
            background: linear-gradient(90deg, #004a99, #0066cc);
            color: white;
            padding: 12px 0; /* Più alto */
            overflow: hidden;
            white-space: nowrap;
            font-weight: bold;
            font-size: 1rem; /* Font più grande */
            text-transform: uppercase;
        }

        .scorrimento {
            display: inline-block;
            padding-left: 100%;
            animation: scorri 20s linear infinite;
        }

        @keyframes scorri {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        /* HEADER - Grande e centrato */
        header {
            width: 100%;
            background-color: white;
            border-bottom: 1px solid #eee;
            padding: 20px 0; /* Più respiro sopra e sotto */
        }

        .header-container {
            max-width: 1300px; /* Molto largo per non sembrare piccolo */
            margin: 0 auto;
            display: grid;
            grid-template-columns: 120px 1fr 120px; /* Colonne laterali più larghe per bilanciare */
            align-items: center;
            padding: 0 30px;
        }

        .logo-img {
            height: 65px; /* Logo più grande, come lo volevi */
            width: auto;
            display: block;
        }

        nav {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 25px; /* Più spazio tra i link */
        }

        nav a {
            text-decoration: none;
            color: #333;
            font-size: 1.1rem; /* Testo menu più grande */
            font-weight: 500;
            transition: color 0.3s;
        }

        nav a:hover { color: #0066cc; }

        /* CONTENUTO PRINCIPALE - Largo e leggibile */
        main {
            max-width: 1100px; /* Aumentato per non far sembrare il sito "stretto" */
            margin: 0 auto;
            padding: 50px 30px;
        }

        /* FOOTER */
        footer {
            width: 100%;
            background-color: #f9f9f9;
            border-top: 1px solid #eee;
            padding: 50px 20px;
            text-align: center;
        }

        .footer-content {
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-content p {
            font-size: 1rem;
            margin: 10px 0;
        }

        /* RESPONSIVE */
        @media (max-width: 900px) {
            .header-container {
                display: flex;
                flex-direction: column;
                gap: 20px;
            }
            .header-spacer { display: none; }
            nav { gap: 15px; }
        }
    </style>
</head>
<body>

    <div class="banner-30">
        <div class="scorrimento">
            30 ANNI DI AMO ❤ 30 ANNI DI AMO ❤ 30 ANNI DI AMO
        </div>
    </div>

    <header>
        <div class="header-container">
            <a href="/sito-associazione/">
                <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" class="logo-img">
            </a>

            <nav>
                <a href="/sito-associazione/"><b>Notizie</b></a>
                <a href="/sito-associazione/chi-siamo">Chi Siamo</a>
                <a href="/sito-associazione/fai-una-donazione">Donazioni</a>
                <a href="/sito-associazione/progetti">Progetti</a>
                <a href="/sito-associazione/servizi">Servizi</a>
                <a href="/sito-associazione/contatti">Contatti</a>
                <a href="/sito-associazione/trasparenza">Trasparenza</a>
            </nav>

            <div class="header-spacer"></div>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-content">
            <p style="font-size: 1.2rem;"><strong>Associazione Malati Oncologici ODV Carpi (MO)</strong></p>
            <p style="color: #666;">
                Via G. Molinari 2, Ospedale Ramazzini, Carpi MO | Tel: 059 6132038<br>
                Email: amocarpi.odv@gmail.com
            </p>
        </div>
    </footer>

</body>
</html>