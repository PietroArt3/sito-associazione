<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>

    <style>
        /* RESET BASE */
        body {
            margin: 0;
            padding: 0;
            font-family: sans-serif;
            line-height: 1.5;
            color: #333;
            background-color: white;
        }

        /* BANNER - Ingrandito come richiesto */
        .banner-30 {
            width: 100%;
            background: linear-gradient(90deg, #004a99, #0066cc);
            color: white;
            padding: 12px 0; /* Aumentato spessore */
            overflow: hidden;
            white-space: nowrap;
            font-weight: bold;
            font-size: 1.1rem; /* Carattere più grande */
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .scorrimento {
            display: inline-block;
            padding-left: 100%;
            animation: scorri 25s linear infinite;
        }

        @keyframes scorri {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        /* HEADER */
        header {
            width: 100%;
            background-color: white;
            border-bottom: 1px solid #eee;
            padding: 10px 0;
        }

        .header-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 100px 1fr 100px;
            align-items: center;
            padding: 0 20px;
        }

        .logo-img {
            height: 50px;
            width: auto;
            display: block;
        }

        /* MENU - Scritte più grandi */
        nav {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 22px;
        }

        nav a {
            text-decoration: none;
            color: #555;
            font-size: 1.1rem; /* Ingrandite scritte menu */
            font-weight: 500;
            transition: all 0.3s;
            padding: 5px 2px;
            border-bottom: 2px solid transparent;
        }

        nav a:hover {
            color: #0066cc;
        }

        /* CLASSE PER TAB ATTIVO */
        nav a.active {
            color: #0066cc !important;
            font-weight: 800 !important;
            border-bottom: 2px solid #0066cc;
        }

        /* MAIN - Ridotto padding superiore per avvicinare contenuti */
        main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px 30px 20px;
        }

        /* FOOTER */
        footer {
            width: 100%;
            background-color: #f9f9f9;
            border-top: 1px solid #eee;
            padding: 30px 20px;
            text-align: center;
            margin-top: 50px;
        }

        .footer-content p {
            font-size: 0.95rem;
            margin: 5px 0;
            color: #555;
        }

        /* MOBILE */
        @media (max-width: 800px) {
            .header-container {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }
            .header-spacer { display: none; }
            nav { gap: 12px; }
            nav a { font-size: 1rem; }
        }
    </style>
</head>
<body>

    <div class="banner-30">
        <div class="scorrimento">
            30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO ❤️ 30 ANNI DI AMO
        </div>
    </div>

    <header>
        <div class="header-container">
            <a href="/sito-associazione/">
                <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" class="logo-img">
            </a>

            <nav id="main-nav">
                <a href="/sito-associazione/">Notizie</a>
                <a href="/sito-associazione/chi-siamo/">Chi Siamo</a>
                <a href="/sito-associazione/fai-una-donazione/">Donazioni</a>
                <a href="/sito-associazione/progetti/">Progetti</a>
                <a href="/sito-associazione/servizi/">Servizi</a>
                <a href="/sito-associazione/contatti/">Contatti</a>
                <a href="/sito-associazione/trasparenza/">Trasparenza</a>
                <a href="/sito-associazione/privacy/">Privacy</a>
            </nav>

            <div class="header-spacer"></div>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-content">
            <p><strong>Associazione Malati Oncologici ODV Carpi (MO)</strong></p>
            <p>Via G. Molinari 2, Ospedale Ramazzini, Carpi MO | Tel: 059 6132038</p>
            <p>Email: amocarpi.odv@gmail.com</p>
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const currentUrl = window.location.pathname;
            const navLinks = document.querySelectorAll('#main-nav a');

            navLinks.forEach(link => {
                const linkPath = link.getAttribute('href');

                // Se l'URL corrente contiene il percorso del link, aggiungi la classe active
                // Gestisce sia il caso della home "/" che le altre pagine
                if (currentUrl === linkPath || (linkPath !== "/sito-associazione/" && currentUrl.includes(linkPath))) {
                    link.classList.add('active');
                }
            });
        });
    </script>

</body>
</html>