<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>
    <link rel="stylesheet" href="/sito-associazione/css/style.css">

<style>
    /* Banner 30 Anni con scorrimento */
    .banner-30 {
        background: linear-gradient(90deg, #004a99, #0066cc);
        color: white;
        padding: 10px 0;
        overflow: hidden;
        white-space: nowrap;
        font-family: sans-serif;
        font-weight: bold;
        letter-spacing: 2px;
        font-size: 0.9rem;
        text-transform: uppercase;
        display: flex;
        align-items: center;
    }

    .scorrimento {
        display: inline-block;
        padding-left: 100%;
        animation: scorri 15s linear infinite;
    }

    @keyframes scorri {
        0% { transform: translateX(0); }
        100% { transform: translateX(-100%); }
    }

    .cuore-animato {
        display: inline-block;
        color: #ff4d4d;
        margin: 0 10px;
        animation: battito 1.5s infinite;
    }

    @keyframes battito {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }

    /* Stile Header e Logo */
    header {
        text-align: center;
        padding: 30px 20px 10px 20px;
        font-family: sans-serif;
    }

    .logo-link {
        display: inline-block;
        margin-bottom: 20px;
        text-decoration: none;
    }

    .logo-img {
        width: 150px; /* Dimensione ideale per il logo in alto */
        height: auto;
        display: block;
        margin: 0 auto;
        transition: transform 0.3s ease;
    }

    .logo-img:hover {
        transform: scale(1.05); /* Effetto delicato al passaggio del mouse */
    }

    /* Navigazione */
    nav {
        padding: 15px 0;
        border-top: 1px solid #f0f0f0;
    }

    nav a {
        text-decoration: none;
        color: #333;
        margin: 0 12px;
        font-size: 0.95rem;
        transition: color 0.3s;
    }

    nav a:hover { color: #0066cc; }

    footer { text-align: center; padding: 40px 20px; font-family: sans-serif; background-color: #f9f9f9; }

    /* Responsive: menu più compatto su mobile */
    @media (max-width: 600px) {
        nav a { display: inline-block; margin: 5px 10px; }
        .logo-img { width: 120px; }
    }
</style>

</head>
<body>

    <div class="banner-30">
        <div class="scorrimento">
            30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO
        </div>
    </div>

    <header>
        <a href="/sito-associazione/" class="logo-link">
            <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO Carpi" class="logo-img">
        </a>

        <nav>
            <a href="/sito-associazione/"><b>Notizie</b></a>
            <a href="/sito-associazione/chi-siamo">Chi Siamo</a>
            <a href="/sito-associazione/fai-una-donazione">Donazioni</a>
            <a href="/sito-associazione/progetti">Progetti</a>
            <a href="/sito-associazione/servizi">Servizi</a>
            <a href="/sito-associazione/contatti">Contatti</a>
            <a href="/sito-associazione/trasparenza">Trasparenza</a>
            <a href="/sito-associazione/privacy">Privacy</a>
        </nav>
    </header>

    <hr style="border: 0; border-top: 1px solid #eee; margin: 0;">

    <main style="max-width: 1000px; margin: 0 auto; padding: 40px 20px;">
        {{ content | safe }}
    </main>

    <footer style="margin-top: 50px; border-top: 1px solid #eee;">
        <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 20px;">
            <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" style="width: 60px; border-radius: 8px; opacity: 0.7;">
            <p style="margin: 0; color: #555;">
                <strong>Associazione Malati Oncologici ODV Carpi (MO)</strong><br>
                <span style="font-size: 0.9rem;">Via G. Molinari 2, Ospedale Ramazzini, Carpi MO | Tel: 059 6132038 - Email: amocarpi.odv@gmail.com</span>
            </p>
        </div>
    </footer>
</body>
</html>