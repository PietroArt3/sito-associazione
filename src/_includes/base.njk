<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | AMO Carpi</title>
    <link rel="stylesheet" href="/sito-associazione/css/style.css">

<style>
    /* Banner 30 Anni con scorrimento */
    .banner-30 {
        background: linear-gradient(90deg, #004a99, #0066cc);
        color: white;
        padding: 10px 0;
        overflow: hidden; /* Nasconde il testo che esce dai bordi */
        white-space: nowrap; /* Impedisce al testo di andare a capo */
        font-family: sans-serif;
        font-weight: bold;
        letter-spacing: 2px;
        font-size: 0.9rem;
        text-transform: uppercase;
        display: flex;
        align-items: center;
    }

    .scorrimento {
        display: inline-block;
        padding-left: 100%; /* Inizia fuori dallo schermo a destra */
        animation: scorri 15s linear infinite;
    }

    @keyframes scorri {
        0% { transform: translateX(0); }
        100% { transform: translateX(-100%); }
    }

    .cuore-animato {
        display: inline-block;
        color: #ff4d4d;
        margin: 0 10px;
        animation: battito 1.5s infinite;
    }

    @keyframes battito {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }

    /* Resto dello stile invariato */
    nav { padding: 20px 0; text-align: center; font-family: sans-serif; }
    nav a { text-decoration: none; color: #333; margin: 0 10px; transition: color 0.3s; }
    nav a:hover { color: #0066cc; }
    footer { text-align: center; padding: 40px 20px; font-family: sans-serif; background-color: #f9f9f9; }
</style>

<div class="banner-30">
    <div class="scorrimento">
        ❤ 30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO <span class="cuore-animato">❤</span>
    </div>
</div>

</head>
<body>

    <header>
        <nav>
            <a href="/sito-associazione/"><b>Notizie</b></a> |
            <a href="/sito-associazione/chi-siamo">Chi Siamo</a> |
            <a href="/sito-associazione/fai-una-donazione">Donazioni</a> |
            <a href="/sito-associazione/progetti">Progetti</a> |
            <a href="/sito-associazione/servizi">Servizi</a> |
            <a href="/sito-associazione/contatti">Contatti</a> |
            <a href="/sito-associazione/trasparenza">Trasparenza</a> |
            <a href="/sito-associazione/privacy">Privacy</a>
        </nav>
    </header>

    <hr style="border: 0; border-top: 1px solid #eee; margin: 0;">

    <main>
        {{ content | safe }}
    </main>

    <footer style="margin-top: 50px; border-top: 1px solid #eee;">
        <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 20px;">
            <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" style="width: 80px; border-radius: 8px;">
            <p style="margin: 0; color: #555;">
                <strong>Associazione Malati Oncologici ODV Carpi (MO)</strong><br>
                <span style="font-size: 0.9rem;">Sempre al fianco di chi ha bisogno.</span>
            </p>
        </div>
    </footer>
</body>
</html>