<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/sito-associazione/img/favicon.png">
    <title>{{ title }} | AMO Carpi</title>
    <link rel="stylesheet" href="/sito-associazione/css/style.css">

<style>
    /* Reset base per evitare margini indesiderati */
    body { margin: 0; font-family: sans-serif; }

    /* Banner 30 Anni con scorrimento */
    .banner-30 {
        background: linear-gradient(90deg, #004a99, #0066cc);
        color: white;
        padding: 8px 0;
        overflow: hidden;
        white-space: nowrap;
        font-weight: bold;
        letter-spacing: 2px;
        font-size: 0.8rem;
        text-transform: uppercase;
        display: flex;
        align-items: center;
    }

    .scorrimento {
        display: inline-block;
        padding-left: 100%;
        animation: scorri 20s linear infinite;
    }

    @keyframes scorri {
        0% { transform: translateX(0); }
        100% { transform: translateX(-100%); }
    }

    .cuore-animato {
        display: inline-block;
        color: #ff4d4d;
        margin: 0 10px;
        animation: battito 1.5s infinite;
    }

    @keyframes battito {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }

    /* Header Compatto con Logo a Sinistra e Menu Centrato */
    header {
        background-color: white;
        border-bottom: 1px solid #eee;
        padding: 10px 20px;
    }

    .header-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 100px 1fr 100px; /* Logo 100px | Menu flessibile | Vuoto 100px */
        align-items: center;
    }

    .logo-img {
        height: 45px; /* Logo molto discreto */
        width: auto;
        display: block;
        transition: opacity 0.3s;
    }

    .logo-img:hover { opacity: 0.8; }

    nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    nav a {
        text-decoration: none;
        color: #444;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 5px 0;
        transition: color 0.3s;
    }

    nav a:hover { color: #0066cc; }
    nav a b { color: #0066cc; } /* Evidenzia 'Notizie' */

    /* Ottimizzazione Mobile */
    @media (max-width: 850px) {
        .header-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .header-spacer { display: none; }
    }

    main {
        max-width: 900px;
        margin: 0 auto;
        padding: 30px 20px;
        line-height: 1.6;
    }

    footer {
        text-align: center;
        padding: 30px 20px;
        background-color: #f9f9f9;
        border-top: 1px solid #eee;
        margin-top: 40px;
    }
</style>
</head>
<body>

    <div class="banner-30">
        <div class="scorrimento">
            30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO <span class="cuore-animato">❤</span> 30 ANNI DI AMO
        </div>
    </div>

    <header>
        <div class="header-container">
            <a href="/sito-associazione/">
                <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" class="logo-img">
            </a>

            <nav>
                <a href="/sito-associazione/"><b>Notizie</b></a>
                <a href="/sito-associazione/chi-siamo">Chi Siamo</a>
                <a href="/sito-associazione/fai-una-donazione">Donazioni</a>
                <a href="/sito-associazione/progetti">Progetti</a>
                <a href="/sito-associazione/servizi">Servizi</a>
                <a href="/sito-associazione/contatti">Contatti</a>
                <a href="/sito-associazione/trasparenza">Trasparenza</a>
                <a href="/sito-associazione/privacy">Privacy</a>
            </nav>

            <div class="header-spacer"></div>
        </div>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 15px;">
            <img src="/sito-associazione/img/amo_logo.avif" alt="Logo AMO" style="width: 50px; opacity: 0.6;">
            <p style="margin: 0; color: #666; font-size: 0.85rem;">
                <strong>Associazione Malati Oncologici ODV Carpi (MO)</strong><br>
                Via G. Molinari 2, Ospedale Ramazzini, Carpi MO<br>
                Tel: 059 6132038 | Email: amocarpi.odv@gmail.com
            </p>
        </div>
    </footer>

</body>
</html>